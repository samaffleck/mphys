{
    "version": 6,
    "configurePresets": [
        {
            "name": "base-common",
            "hidden": true,
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_STANDARD": "23"
            }
        },
        {
            "name": "base",
            "hidden": true,
            "inherits": "base-common",
            "description": "macOS toolchain (Homebrew LLVM clang with C++23 support)",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
                "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
            }
        },
        {
            "name": "mac-debug",
            "displayName": "macOS Debug",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/mac-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS_DEBUG": "-O0 -g3 -fno-omit-frame-pointer -fstandalone-debug",
                "CMAKE_C_FLAGS_DEBUG":   "-O0 -g3 -fno-omit-frame-pointer -fstandalone-debug",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "ON"
            }
        },
        {
            "name": "mac-release",
            "displayName": "macOS Release",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/mac-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "ON"
            }
        },
        {
            "name": "mac-coverage",
            "displayName": "macOS Coverage",
            "inherits": "base",
            "binaryDir": "${sourceDir}/build/mac-coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "-fprofile-instr-generate -fcoverage-mapping -O0 -g",
                "CMAKE_C_FLAGS": "-fprofile-instr-generate -fcoverage-mapping -O0 -g",
                "CMAKE_EXE_LINKER_FLAGS": "-fprofile-instr-generate",
                "MPHYS_COVERAGE": "ON",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "OFF",
                "BUILD_EXAMPLES": "OFF"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "inherits": "base-common",
            "description": "Uses the default system compiler from PATH (GCC 14+ or Clang 18+ for C++23 <print> support)",
            "binaryDir": "${sourceDir}/build/linux-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "OFF"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "inherits": "base-common",
            "description": "Uses the default system compiler from PATH (GCC 14+ or Clang 18+ for C++23 <print> support)",
            "binaryDir": "${sourceDir}/build/linux-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "ON",
                "BUILD_GUI": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "mac-debug",
            "configurePreset": "mac-debug",
            "jobs": 8
        },
        {
            "name": "mac-release",
            "configurePreset": "mac-release",
            "jobs": 8
        },
        {
            "name": "mac-debug-gui",
            "displayName": "macOS Debug — GUI only",
            "configurePreset": "mac-debug",
            "targets": ["mphys_gui"],
            "jobs": 8
        },
        {
            "name": "mac-release-gui",
            "displayName": "macOS Release — GUI only",
            "configurePreset": "mac-release",
            "targets": ["mphys_gui"],
            "jobs": 8
        },
        {
            "name": "mac-coverage",
            "configurePreset": "mac-coverage",
            "targets": ["mphys_tests"],
            "jobs": 8
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug",
            "jobs": 8
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release",
            "jobs": 8
        }
    ]
}
