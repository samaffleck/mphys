{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (Debug)",
            "type": "shell",
            "command": "cmake --preset mac-debug",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "CMake: Configure (Release)",
            "type": "shell",
            "command": "cmake --preset mac-release",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "CMake: Build (Debug)",
            "type": "shell",
            "command": "cmake --build --preset mac-debug",
            "options": { "cwd": "${workspaceFolder}" },
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake: Build (Release)",
            "type": "shell",
            "command": "cmake --build --preset mac-release",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake: Build GUI (Debug)",
            "type": "shell",
            "command": "cmake --build --preset mac-debug-gui",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake: Build GUI (Release)",
            "type": "shell",
            "command": "cmake --build --preset mac-release-gui",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$gcc"
        },
        {
            "label": "CMake: Run Tests (Debug)",
            "type": "shell",
            "command": "ctest --test-dir build/mac-debug --output-on-failure",
            "options": { "cwd": "${workspaceFolder}" },
            "group": "test",
            "presentation": { "reveal": "always", "panel": "shared" }
        }
    ]
}
